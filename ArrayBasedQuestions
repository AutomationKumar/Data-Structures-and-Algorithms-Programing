import java.util.Arrays;
import java.util.HashSet;

public class ArrayQuestions {
    1. Find Largest Element in Array

    public static int findLargest(int[] arr) {
        int max = arr[0];
        for (int num : arr) {
            if (num > max) {
                max = num;
            }
        }
        return max;
    }

     2. Reverse an Array
    public static void reverseArray(int[] arr) {

        int start = 0;
        int end = arr.length - 1;

        while (start < end) {

            int temp = arr[start];
            arr[start] = arr[end];
            arr[end] = temp;

            start++;
            end--;
        }
    }

    3. Find Duplicate Element
    public static void findDuplicate(int[] arr) {

        HashSet<Integer> set = new HashSet<>();

        for (int num : arr) {

            if (set.contains(num)) {
                System.out.println("Duplicate Element: " + num);
            } else {
                set.add(num);
            }
        }
    }

    4. Find Second Largest Element
    public static int findSecondLargest(int[] arr) {

        int largest = Integer.MIN_VALUE;
        int secondLargest = Integer.MIN_VALUE;

        for (int num : arr) {

            if (num > largest) {
                secondLargest = largest;
                largest = num;

            } else if (num > secondLargest && num != largest) {
                secondLargest = num;
            }
        }

        return secondLargest;
    }

5 . Find Maximum and Minimum Element
public static void findMaxMin(int[] arr) {

    int max = arr[0];
    int min = arr[0];

    for (int num : arr) {

        if (num > max) {
            max = num;
        }

        if (num < min) {
            min = num;
        }
    }

    System.out.println("Maximum Element : " + max);
    System.out.println("Minimum Element : " + min);
}

   6. public static int maxSubarraySum(int[] arr) {

        int maxSum = arr[0];
        int currentSum = arr[0];

        for (int i = 1; i < arr.length; i++) {

            currentSum = Math.max(arr[i],
                    currentSum + arr[i]);

            maxSum = Math.max(maxSum, currentSum);
        }

        return maxSum;
    }
7. public static void twoSum(int[] arr, int target) {

        HashMap<Integer, Integer> map = new HashMap<>();

        for (int i = 0; i < arr.length; i++) {

            int difference = target - arr[i];

            if (map.containsKey(difference)) {

                System.out.println("Two Sum Pair : "
                        + difference + " , " + arr[i]);

                return;
            }

            map.put(arr[i], i);
        }
    }

8 .public static void moveZerosToEnd(int[] arr) {

        int index = 0;

        for (int num : arr) {

            if (num != 0) {

                arr[index++] = num;
            }
        }

        while (index < arr.length) {

            arr[index++] = 0;
        }

        System.out.println("After Moving Zeros : "
                + Arrays.toString(arr));
    }
}
